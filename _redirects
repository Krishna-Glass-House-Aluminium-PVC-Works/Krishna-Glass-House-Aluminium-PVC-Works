# Redirect to non-www and HTTPS (Cloudflare does this by default if enabled, but good to have)
# https://krishnaglass.explyra.me/* https://krishnaglass.explyra.me/:splat 301!

# Handle index.html to / for SEO (Canonicalize)
/index.html / 301

# Clean URLs for .html extension (Cloudflare handles this often, but explicit is better)
/about.html /about 301
/contact.html /contact 301
/services.html /services 301
/gallery.html /portfolio 301

# Handle common PHP variants if migrating from an older site
/*.php / 301

# Custom 404 handler (Cloudflare automatically looks for 404.html too)
/* /404.html 404
